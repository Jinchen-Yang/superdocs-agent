# ── 数据库 ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/superdocs_agent

# ── 模型 API key（按需填；缺哪个，对应提供商的模型即不可用并报错）──
DEEPSEEK_API_KEY=sk-xxx
# 小米 MiMo（OpenAI 兼容，Base URL: https://token-plan-cn.xiaomimimo.com/v1；按月续费 credits 计费）
MIMO_API_KEY=

# ── 会话签名密钥 ───────────────────────────────────────
# 生产(NODE_ENV=production)必填，否则启动即报错（防 token 伪造）。
# 生成：openssl rand -hex 32
APP_SESSION_SECRET=change-me-please-use-a-long-random-string

# ── 运行 ───────────────────────────────────────────────
# 生产置 production：启用 Secure cookie + 强制校验 APP_SESSION_SECRET
NODE_ENV=development
PORT=3100
# 前端构建产物目录（web/ 经 vite build 生成）；留空默认取「运行目录/web/dist」
NEXT_DIR=
# 文档检索索引 metadata.json 路径；留空默认「运行目录/data/metadata.json」
METADATA_PATH=
# 可选：pg 连接池上限（默认 10）
# PG_POOL_MAX=10
# 可选：单条 SQL 超时毫秒（默认 15000；0=不限），防慢查询长期占用连接
# PG_STATEMENT_TIMEOUT_MS=15000

# ── 反代 / 真实客户端 IP（影响校园门禁 + 限流，务必正确配置）──────────
# X-Forwarded-For 整体是「客户端可伪造」的，不能直接信。两种取真实 IP 的方式：
#   方式一(推荐)：nginx 写 `proxy_set_header X-Real-IP $remote_addr;`（会覆盖客户端伪造值），
#                 应用默认(TRUSTED_PROXY_HOPS=0)只认 X-Real-IP。
#   方式二：设 TRUSTED_PROXY_HOPS=「应用与客户端之间我们掌控的反代层数」(nginx=1)，
#           应用取 X-Forwarded-For 从右数第 N 个条目作为真实 IP。
# 前提：应用端口绝不直接暴露公网，只经反代访问（本项目经反向 SSH 隧道仅监听 localhost，满足）。
TRUSTED_PROXY_HOPS=0

# ── 超时（毫秒，可选）─────────────────────────────────────
# 大模型上游响应头超时（开始返回后不再约束流式 body，默认 30000）
# LLM_TIMEOUT_MS=30000
# 统一认证 buptLogin 单次等待上限（默认 20000）
# SSO_TIMEOUT_MS=20000
# 验证码图片 / OCR 服务请求超时（默认 10000）
# OCR_TIMEOUT_MS=10000

# ── 校园门禁 / 北邮统一认证（可选）─────────────────────
# on 时把使用范围限制为「校园网 IP 段内」或「北邮 SSO 认证用户」；默认 off。
CAMPUS_GATE=off
# 校园网公网段（逗号分隔 IPv4/IPv6 CIDR）；在校园网内访问 /app/auth/whoami 看返回的 ip 来确定。
# 例：CAMPUS_CIDRS=211.68.0.0/16,2001:da8:215::/48
CAMPUS_CIDRS=
# 自建验证码 OCR 服务（POST 图片字节 → {"text":"..."}），如 ddddocr；用于 SSO 自动过验证码。
# 留空则仅在北邮恰好不弹验证码时可 SSO 登录。例：OCR_URL=http://127.0.0.1:8190/
OCR_URL=

# ── 管理统计页（可选）─────────────────────────────────
# 管理员名单（逗号分隔的「学号」，即统一认证回填的 external_id）；仅名单内账号能看 /app/admin/stats。
# 只认学号、不认用户名——用户名可被任意抢注，拿来判权限会被提权。
ADMIN_IDS=

# ── 内嵌气泡 widget（可选）─────────────────────────────
# 允许把 /app/ui 内嵌的宿主站（逗号分隔 origin），如 https://byrdocs.org；'self'(本站)始终允许。
EMBED_ORIGINS=
# 跨站单点登录密钥：宿主站后端用它签 HS256 token(含学号 sub)，本服务验签后自动建会话；留空=关闭(气泡内自行登录)。
EMBED_JWT_SECRET=
