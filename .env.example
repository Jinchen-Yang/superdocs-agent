# ── 数据库 ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/superdocs_agent

# ── 模型 API key（按需填；缺哪个，对应提供商的模型即不可用并报错）──
DEEPSEEK_API_KEY=sk-xxx
ZHIPU_API_KEY=
QWEN_API_KEY=

# ── 会话签名密钥 ───────────────────────────────────────
# 生产(NODE_ENV=production)必填，否则启动即报错（防 token 伪造）。
# 生成：openssl rand -hex 32
APP_SESSION_SECRET=change-me-please-use-a-long-random-string

# ── 运行 ───────────────────────────────────────────────
# 生产置 production：启用 Secure cookie + 强制校验 APP_SESSION_SECRET
NODE_ENV=development
PORT=3100
# 前端构建产物目录（web/ 经 vite build 生成）；留空默认取「运行目录/web/dist」
NEXT_DIR=
# 文档检索索引 metadata.json 路径；留空默认「运行目录/data/metadata.json」
METADATA_PATH=
# 可选：pg 连接池上限（默认 10）
# PG_POOL_MAX=10
