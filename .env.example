# ── 数据库 ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/superdocs_agent

# ── 模型 API key（按需填；缺哪个，对应提供商的模型即不可用并报错）──
DEEPSEEK_API_KEY=sk-xxx
ZHIPU_API_KEY=
QWEN_API_KEY=

# ── 会话签名密钥 ───────────────────────────────────────
# 生产(NODE_ENV=production)必填，否则启动即报错（防 token 伪造）。
# 生成：openssl rand -hex 32
APP_SESSION_SECRET=change-me-please-use-a-long-random-string

# ── 运行 ───────────────────────────────────────────────
# 生产置 production：启用 Secure cookie + 强制校验 APP_SESSION_SECRET
NODE_ENV=development
PORT=3100
# 前端构建产物目录（web/ 经 vite build 生成）；留空默认取「运行目录/web/dist」
NEXT_DIR=
# 文档检索索引 metadata.json 路径；留空默认「运行目录/data/metadata.json」
METADATA_PATH=
# 可选：pg 连接池上限（默认 10）
# PG_POOL_MAX=10

# ── 校园门禁 / 北邮统一认证（可选）─────────────────────
# on 时把使用范围限制为「校园网 IP 段内」或「北邮 SSO 认证用户」；默认 off。
CAMPUS_GATE=off
# 校园网公网段（逗号分隔 IPv4/IPv6 CIDR）；在校园网内访问 /app/auth/whoami 看返回的 ip 来确定。
# 例：CAMPUS_CIDRS=211.68.0.0/16,2001:da8:215::/48
CAMPUS_CIDRS=
# 自建验证码 OCR 服务（POST 图片字节 → {"text":"..."}），如 ddddocr；用于 SSO 自动过验证码。
# 留空则仅在北邮恰好不弹验证码时可 SSO 登录。例：OCR_URL=http://127.0.0.1:8190/
OCR_URL=

# ── 管理统计页（可选）─────────────────────────────────
# 管理员名单（逗号分隔的 学号 或 用户名）；仅名单内账号能看 /app/admin/stats（用户数 / Token 消耗）。
ADMIN_IDS=
